    {"type": "timeseries", "title": "Producer latency p95 (s) per topic", "datasource": {"type": "prometheus", "uid": "mimir"}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}, "targets": [{"refId": "A", "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{span_kind=\"SPAN_KIND_PRODUCER\"}[1m])))", "legendFormat": "{{span_name}}"}]}
  ]
